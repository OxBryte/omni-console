{
  "name": "omniconsole",
  "version": "1.0.3",
  "description": "Customizable, in-app developer toolbar (Console, Network, Application)",
  "homepage": "https://console.oxbryte.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OxBryte/omni-console.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/OxBryte/omni-console/issues"
  },
  "main": "./dist/omniconsole.umd.js",
  "module": "./dist/omniconsole.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/omniconsole.mjs",
      "require": "./dist/omniconsole.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "watch": "vite build --watch"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1"
  }
}
